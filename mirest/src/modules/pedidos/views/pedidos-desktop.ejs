<%# @variant: desktop %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= pageTitle %></title>
  <meta name="description" content="Pedidos MiRestcon IA para operación desktop.">
  <meta name="theme-color" content="#ef520f">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/tokens-v2.css">
  <link rel="stylesheet" href="/css/pedidos-v2.css">
</head>
<body>
  <main class="desktop-frame" data-variant="desktop">
    <aside class="desktop-sidebar" aria-label="Navegación desktop">
      <div class="desktop-brand">
        <div class="desktop-brand__logo" aria-hidden="true">IA</div>
        <div><strong>MiRestcon IA</strong><br><span>Gestión operativa</span></div>
      </div>
      <nav class="desktop-nav">
        <span class="desktop-nav__section">OPB</span>
        <button type="button"><span>▣</span>Caja</button>
        <button class="is-active" type="button"><span>◉</span>Pedidos</button>
        <div class="desktop-nav__submenu">
          <a href="#salon">Mesas</a>
          <a href="#todos">Todos</a>
          <a href="#delivery">Delivery</a>
          <a href="#takeaway">Para llevar</a>
        </div>
        <button type="button"><span>⌂</span>Cocina</button>
        <button type="button"><span>↗</span>Ventas</button>
        <span class="desktop-nav__section">CORAZÓN</span>
        <button type="button"><span>⌘</span>Almacén</button>
        <button type="button"><span>▦</span>Productos</button>
        <button type="button"><span>▤</span>Clientes</button>
        <span class="desktop-nav__section">ADMINISTRACIÓN</span>
        <button type="button"><span>▥</span>Facturación</button>
        <button type="button"><span>▨</span>Reportes</button>
      </nav>
    </aside>

    <section class="desktop-main">
      <header class="desktop-header mi-admin-panel-header">
        <div>
          <h1>Pedidos</h1>
          <p><%= greeting %></p>
        </div>
        <button class="mi-btn mi-btn--primary" type="button">+ Agregar</button>
      </header>

      <section class="desktop-summary" aria-label="Resumen del turno">
        <article class="mi-card"><span>Ocupadas</span><strong><%= stats.ocupadas %></strong></article>
        <article class="mi-card"><span>Libres</span><strong><%= stats.libres %></strong></article>
        <article class="mi-card"><span>Delivery</span><strong><%= stats.deliveryPendientes %></strong></article>
        <article class="mi-card"><span>Recojo</span><strong><%= stats.takeawayPendientes %></strong></article>
      </section>

      <section class="desktop-workspace mi-card" aria-label="Mesas de salón">
        <div class="desktop-workspace__head">
          <h2>Salón en vivo</h2>
          <span class="mi-badge"><%= tables.length %> mesas</span>
        </div>
        <div class="desktop-table-grid">
          <% tables.forEach((table) => { %>
            <button class="desktop-table-card desktop-table-card--<%= table.status %>" type="button" data-table-id="<%= table.id %>">
              <span class="desktop-table-card__top">
                <span class="mi-badge <%= table.status === 'ocupada' ? 'mi-badge--danger' : table.status === 'reservada' ? 'mi-badge--info' : 'mi-badge--success' %>"><%= table.status %></span>
                <strong class="mi-price"><%= table.totalLabel %></strong>
              </span>
              <h3>Mesa <%= table.number %></h3>
              <p><%= table.zone %> · <%= table.waiterName %> · <%= table.itemsCount %> ítems</p>
            </button>
          <% }) %>
        </div>
      </section>
    </section>

    <aside class="desktop-panel mi-card" aria-label="Panel de pedido activo">
      <h2>Pedido activo</h2>
      <p>Selecciona una mesa para inspeccionar rondas, cobrar o enviar nuevos ítems a cocina.</p>
      <div class="desktop-panel__total">
        <span>Total estimado del turno</span>
        <strong class="mi-price"><%= totals.turnTotalLabel %></strong>
      </div>
      <button class="mi-btn mi-btn--success" type="button">✓ Registrar pago</button>
      <button class="mi-btn mi-btn--ghost" type="button">Añadir ronda</button>
    </aside>
  </main>
</body>
</html>
