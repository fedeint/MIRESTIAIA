<%# @variant: pwa %>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= pageTitle %></title>
  <meta name="description" content="Pedidos MiRestcon IA para operación PWA mobile-first.">
  <meta name="theme-color" content="#ef520f">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/tokens-v2.css">
  <link rel="stylesheet" href="/css/pedidos-v2.css">
</head>
<body>
  <main class="mi-shell pwa-frame" data-variant="pwa">
    <header class="pwa-header mi-admin-panel-header">
      <div class="pwa-header__top">
        <span>MiRestcon IA</span>
        <span class="mi-badge mi-badge--success"><%= sessionLabel %></span>
      </div>
      <h1>Pedidos</h1>
      <p><%= greeting %></p>
    </header>

    <nav class="pwa-tabs" aria-label="Áreas de pedido">
      <button class="pwa-tab is-active" type="button">Salón</button>
      <button class="pwa-tab" type="button">Delivery</button>
      <button class="pwa-tab" type="button">Recojo</button>
    </nav>

    <section class="pwa-summary" aria-label="Resumen del turno">
      <article class="mi-card"><span>Ocupadas</span><strong><%= stats.ocupadas %></strong></article>
      <article class="mi-card"><span>Libres</span><strong><%= stats.libres %></strong></article>
      <article class="mi-card"><span>Delivery</span><strong><%= stats.deliveryPendientes %></strong></article>
      <article class="mi-card"><span>Recojo</span><strong><%= stats.takeawayPendientes %></strong></article>
    </section>

    <section class="pwa-dashboard-panel mi-card" aria-label="Mesas de salón">
      <div class="pwa-section-title">
        <h2>Mesas activas</h2>
        <span class="mi-badge"><%= tables.length %> mesas</span>
      </div>
      <div class="pwa-table-list">
        <% tables.forEach((table) => { %>
          <button class="pwa-table-card pwa-table-card--<%= table.status %>" type="button" data-table-id="<%= table.id %>">
            <span class="pwa-table-card__row">
              <span class="mi-badge <%= table.status === 'ocupada' ? 'mi-badge--danger' : table.status === 'reservada' ? 'mi-badge--info' : 'mi-badge--success' %>"><%= table.status %></span>
              <strong class="mi-price"><%= table.totalLabel %></strong>
            </span>
            <h3>Mesa <%= table.number %></h3>
            <p><%= table.zone %> · <%= table.waiterName %> · <%= table.itemsCount %> ítems</p>
          </button>
        <% }) %>
      </div>
    </section>
  </main>
  <nav class="pwa-bottom-nav" aria-label="Navegación PWA">
    <button class="is-active" type="button">▣ Salón</button>
    <button type="button">Pedido</button>
    <button type="button">Caja</button>
    <button type="button">Perfil</button>
  </nav>
</body>
</html>
